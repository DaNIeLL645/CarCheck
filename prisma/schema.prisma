generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  password       String
  fullName       String
  phone          String?
  role           String       @default("CLIENT")
  
  // --- NOU: Credite pentru pachetele de verificări ---
  credits        Int          @default(0)
  
  createdAt      DateTime     @default(now())
  
  // Relații existente
  clientOrders   Inspection[] @relation("ClientInspections")
  mechanicOrders Inspection[] @relation("MechanicInspections")
  
  // Relația pentru Recenziile primite de mecanic
  reviews        Review[]     @relation("MechanicReviews")

  // --- NOU: Relația pentru mesajele trimise de acest utilizator ---
  messages       Message[]
}

model Inspection {
  id               String   @id @default(uuid())
  
  carUrl           String
  carMake          String?
  carModel         String?
  price            Int?     @default(150)
  status           String   @default("PENDING")
  location         String
  
  clientId         String
  client           User     @relation("ClientInspections", fields: [clientId], references: [id])
  
  mechanicId       String?
  mechanic         User?    @relation("MechanicInspections", fields: [mechanicId], references: [id])
  
  reportDetails    String?
  photosUrls       String?
  engineMediaUrl   String?
  diagnosticUrl    String?
  model3dUrl       String?

  review           Review?
  
  // --- NOU PENTRU STRIPE ---
  stripeSessionId  String?
  paymentStatus    String   @default("UNPAID")
  // -------------------------

  // --- NOU: Relația către mesajele (chat-ul) acestei inspecții ---
  messages         Message[]

  createdAt        DateTime @default(now())
}

// --- NOU: Modelul pentru Chat ---
model Message {
  id           String     @id @default(uuid())
  content      String     // Conținutul text al mesajului
  createdAt    DateTime   @default(now()) // Când a fost trimis

  // Legăm mesajul de inspecția (anunțul) la care se referă
  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  // Legăm mesajul de expeditor (Client sau Mecanic)
  senderId     String
  sender       User       @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Review {
  id           String     @id @default(uuid())
  rating       Int        // O notă de la 1 la 5
  comment      String?    // Comentariul clientului (opțional)
  
  // Legăm recenzia de o anumită inspecție (o inspecție = o singură recenzie)
  inspectionId String     @unique
  inspection   Inspection @relation(fields: [inspectionId], references: [id])
  
  // Legăm recenzia de mecanicul care a făcut inspecția
  mechanicId   String
  mechanic     User       @relation("MechanicReviews", fields: [mechanicId], references: [id])

  createdAt    DateTime   @default(now())
}